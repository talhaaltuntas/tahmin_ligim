<!DOCTYPE html><html class="dark" lang="tr" style=""><head>
<meta charset="utf-8">
<meta content="width=device-width, initial-scale=1.0" name="viewport">
<title>FootyVision Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet">
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
  tailwind.config = {
    darkMode: "class",
    theme: {
      extend: {
        "colors": {
                "surface-bright": "#393939",
                "surface-variant": "#353535",
                "on-primary-container": "#00285c",
                "on-primary": "#002e69",
                "background": "#131313",
                "on-tertiary": "#571e00",
                "on-secondary-fixed": "#002107",
                "inverse-surface": "#e2e2e2",
                "on-tertiary-fixed-variant": "#7c2e00",
                "on-error-container": "#ffdad6",
                "on-secondary-container": "#003a11",
                "tertiary-fixed-dim": "#ffb595",
                "primary-fixed-dim": "#adc6ff",
                "on-primary-fixed-variant": "#004493",
                "error": "#ffb4ab",
                "tertiary-container": "#ef6719",
                "surface": "#131313",
                "surface-container-highest": "#353535",
                "inverse-on-surface": "#303030",
                "secondary-fixed": "#72fe88",
                "on-secondary-fixed-variant": "#00531c",
                "tertiary-fixed": "#ffdbcc",
                "error-container": "#93000a",
                "secondary-container": "#05b046",
                "on-surface": "#e2e2e2",
                "surface-container-lowest": "#0e0e0e",
                "primary-fixed": "#d8e2ff",
                "on-surface-variant": "#c1c6d7",
                "on-background": "#e2e2e2",
                "surface-tint": "#adc6ff",
                "inverse-primary": "#005bc1",
                "primary-container": "#4b8eff",
                "outline": "#8b90a0",
                "surface-dim": "#131313",
                "secondary": "#53e16f",
                "on-tertiary-container": "#4c1a00",
                "on-error": "#690005",
                "tertiary": "#ffb595",
                "on-primary-fixed": "#001a41",
                "surface-container-high": "#2a2a2a",
                "secondary-fixed-dim": "#53e16f",
                "outline-variant": "#414755",
                "primary": "#adc6ff",
                "on-tertiary-fixed": "#351000",
                "on-secondary": "#003911",
                "surface-container": "#1f1f1f",
                "surface-container-low": "#1b1b1b"
        },
        "borderRadius": {
                "DEFAULT": "1rem",
                "lg": "2rem",
                "xl": "3rem",
                "full": "9999px"
        },
        "spacing": {
                "margin-mobile": "16px",
                "nav-width": "80px",
                "unit": "4px",
                "margin-desktop": "64px",
                "gutter": "24px"
        },
        "fontFamily": {
                "display-lg": [
                        "Inter"
                ],
                "label-sm": [
                        "Inter"
                ],
                "body-md": [
                        "Inter"
                ],
                "headline-lg": [
                        "Inter"
                ],
                "headline-lg-mobile": [
                        "Inter"
                ]
        },
        "fontSize": {
                "display-lg": [
                        "48px",
                        {
                                "lineHeight": "56px",
                                "letterSpacing": "-0.02em",
                                "fontWeight": "700"
                        }
                ],
                "label-sm": [
                        "12px",
                        {
                                "lineHeight": "16px",
                                "letterSpacing": "0.02em",
                                "fontWeight": "500"
                        }
                ],
                "body-md": [
                        "16px",
                        {
                                "lineHeight": "24px",
                                "letterSpacing": "0em",
                                "fontWeight": "400"
                        }
                ],
                "headline-lg": [
                        "32px",
                        {
                                "lineHeight": "40px",
                                "letterSpacing": "-0.01em",
                                "fontWeight": "600"
                        }
                ],
                "headline-lg-mobile": [
                        "24px",
                        {
                                "lineHeight": "32px",
                                "letterSpacing": "-0.01em",
                                "fontWeight": "600"
                        }
                ]
        }
},
    },
  }
</script>
</head>
<body class="text-on-background font-body-md min-h-screen antialiased flex selection:bg-primary/30 selection:text-primary-fixed min-h-screen" style="background: linear-gradient(180deg, #091f15 0%, #050a07 60%, #0c0c0c 100%);">
<!-- Top App Bar -->
<header class="fixed top-0 left-0 right-0 flex justify-between items-center px-margin-mobile md:px-margin-desktop py-gutter bg-transparent z-40 transition-opacity duration-300" id="top-app-bar"><div class="flex justify-between items-center w-full md:ml-[104px]"><div class="flex items-center gap-4"><h1 class="font-headline-lg text-headline-lg font-bold text-white tracking-tighter">FootyVision</h1></div><div class="flex items-center gap-6"><button aria-label="Notifications" class="text-on-surface hover:text-white transition-colors focus:outline-none"><span class="material-symbols-outlined" style="font-size: 28px;">notifications</span></button><button aria-label="Profile" class="text-on-surface hover:text-white transition-colors focus:outline-none"><span class="material-symbols-outlined" style="font-size: 28px;">account_circle</span></button></div></div></header>
<!-- Side Navigation Capsule (Desktop Only) -->
<nav class="hidden md:flex fixed left-6 top-1/2 -translate-y-1/2 h-auto py-8 w-nav-width rounded-full shadow-2xl flex-col items-center gap-8 z-50 backdrop-blur-[64px] bg-white/5 border border-white/10 border-t-white/20 border-l-white/20 max-h-[90vh] overflow-y-auto">
<!-- Active Tab: Home -->
<a aria-current="page" aria-label="Home" class="flex flex-col items-center justify-center w-14 h-14 rounded-full text-white bg-white/10 shadow-[0_0_15px_rgba(255,255,255,0.1),inset_0_1px_1px_rgba(255,255,255,0.3)] border border-white/20 transition-all duration-200 group relative" href="#">
<span class="material-symbols-outlined" style="font-size: 28px; font-variation-settings: &quot;FILL&quot; 1;">sports_soccer</span>
<span class="font-label-sm text-[10px] mt-1 text-white transition-colors">Ana Sayfa</span>
</a>
<!-- Inactive Tabs -->
<a aria-label="Matches" class="flex flex-col items-center justify-center w-14 h-14 rounded-full text-on-surface-variant hover:bg-white/5 hover:text-white transition-all duration-300 group" href="#">
<span class="material-symbols-outlined" style="font-size: 28px;">calendar_month</span>
<span class="font-label-sm text-[10px] mt-1 text-on-surface-variant group-hover:text-white transition-colors">Maçlar</span>
</a>
<a aria-label="Forum" class="flex flex-col items-center justify-center w-14 h-14 rounded-full text-on-surface-variant hover:bg-white/5 hover:text-white transition-all duration-300 group" href="#">
<span class="material-symbols-outlined" style="font-size: 28px;">forum</span>
<span class="font-label-sm text-[10px] mt-1 text-on-surface-variant group-hover:text-white transition-colors">Forum</span>
</a><a aria-label="Leagues" class="flex flex-col items-center justify-center w-14 h-14 rounded-full text-on-surface-variant hover:bg-white/5 hover:text-white transition-all duration-300 group" href="#">
<span class="material-symbols-outlined" style="font-size: 28px;">trophy</span>
<span class="font-label-sm text-[10px] mt-1 text-on-surface-variant group-hover:text-white transition-colors">Ligim</span>
</a>
<div class="flex-grow min-h-[40px]"></div>
<a aria-label="Settings" class="flex flex-col items-center justify-center w-14 h-14 rounded-full text-on-surface-variant hover:bg-white/5 hover:text-white transition-all duration-300 group" href="#">
<span class="material-symbols-outlined" style="font-size: 28px;">settings</span>
<span class="font-label-sm text-[10px] mt-1 text-on-surface-variant group-hover:text-white transition-colors">Ayarlar</span>
</a>
</nav>
<!-- Main Content Canvas -->
<main class="flex-1 ml-0 md:ml-[calc(24px+80px+24px)] mt-[100px] px-margin-mobile md:px-margin-desktop pb-margin-desktop max-w-7xl relative z-10 md:ml-[140px] flex-grow">
<!-- Hero Section: Featured Match -->
<section class="mb-12">
<div class="bg-white/5 backdrop-blur-[64px] border border-white/10 border-t-white/20 border-l-white/20 rounded-2xl p-8 relative overflow-hidden group shadow-2xl">
<!-- Navigation Arrows -->
<button class="absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/5 flex items-center justify-center opacity-100 hover:bg-white/10 transition-all text-white border border-white/10 z-20">
<span class="material-symbols-outlined">chevron_left</span>
</button>
<button class="absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/5 flex items-center justify-center opacity-100 hover:bg-white/10 transition-all text-white border border-white/10 z-20">
<span class="material-symbols-outlined">chevron_right</span>
</button>
<div class="flex flex-col md:flex-row justify-between items-center relative z-10 gap-8">
<!-- Team 1 -->
<div class="flex flex-col items-center space-y-4">
<div class="w-24 h-24 rounded-full bg-white/5 border border-white/10 flex items-center justify-center shadow-lg backdrop-blur-[64px]">
<span class="material-symbols-outlined text-4xl text-white">sports_soccer</span>
</div>
<h2 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-white font-semibold tracking-tight">Galatasaray</h2>
<span class="px-4 py-1 rounded-full bg-white/10 text-on-surface-variant font-label-sm text-label-sm backdrop-blur-sm border border-white/10">Ev Sahibi</span>
</div>
<!-- Match Details -->
<div class="flex flex-col items-center text-center space-y-2">
<span class="text-on-surface-variant font-label-sm tracking-widest uppercase font-medium">Süper Lig - 34. Hafta</span>
<div class="text-display-lg font-display-lg font-bold text-white flex items-baseline gap-4 tracking-tighter">
<span class="">VS</span>
</div>
<span class="text-on-surface-variant font-body-md mt-2 flex items-center gap-2 font-medium">
<span class="material-symbols-outlined text-sm">schedule</span>
                Bugün, 19:00
            </span>
<div class="mt-6 flex gap-4">
<button class="px-6 py-3 rounded-full bg-white/10 text-white border border-white/20 hover:bg-white/20 transition-colors font-label-sm text-label-sm flex items-center gap-2 font-semibold shadow-lg backdrop-blur-md">
<span class="material-symbols-outlined text-lg">query_stats</span>
                    Hemen Tahmin Et
                </button>
</div>
</div>
<!-- Team 2 -->
<div class="flex flex-col items-center space-y-4">
<div class="w-24 h-24 rounded-full bg-white/5 border border-white/10 flex items-center justify-center shadow-lg backdrop-blur-[64px]">
<span class="material-symbols-outlined text-4xl text-white">sports_soccer</span>
</div>
<h2 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-white font-semibold tracking-tight">Fenerbahçe</h2>
<span class="px-4 py-1 rounded-full bg-white/10 text-on-surface-variant font-label-sm text-label-sm backdrop-blur-sm border border-white/10">Deplasman</span>
</div>
</div>
<!-- Carousel Indicators -->
<div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-1.5">
<div class="w-1.5 h-1.5 rounded-full bg-white shadow-sm"></div>
<div class="w-1.5 h-1.5 rounded-full bg-white/20"></div>
<div class="w-1.5 h-1.5 rounded-full bg-white/20"></div>
</div>
</div>
</section>
<!-- Bento Grid: Active Predictions & Insights -->
<section class="grid grid-cols-1 md:grid-cols-3 gap-6">
<!-- Insight Card 1 -->
<div class="bg-white/5 backdrop-blur-[64px] border border-white/10 border-t-white/20 border-l-white/20 rounded-2xl p-6 col-span-1 md:col-span-2 flex flex-col justify-between shadow-xl">
<div class="flex justify-between items-start mb-6">
<h3 class="font-headline-lg text-headline-lg-mobile text-white flex items-center gap-2 font-semibold tracking-tight">
<span class="material-symbols-outlined text-white">trending_up</span>
                        Performans Metrikleri
                    </h3>
<span class="text-on-surface-variant text-sm">Son 5 Maç</span>
</div>
<div class="flex-grow flex items-center justify-center bg-black/20 rounded-lg border border-white/10 p-4 min-h-[200px]">
<p class="text-on-surface-variant text-sm italic">Grafik görselleştirmesi burada yer alacak.</p>
</div>
</div>
<!-- Active Prediction Card -->
<div class="bg-white/5 backdrop-blur-[64px] border border-white/10 border-t-white/20 border-l-white/20 rounded-2xl p-6 flex flex-col gap-4 shadow-xl">
<h3 class="font-headline-lg text-headline-lg-mobile text-white mb-2 font-semibold tracking-tight">Popüler Tahminler</h3>
<div class="bg-black/20 rounded-md p-4 border border-white/10">
<div class="flex justify-between items-center mb-2">
<span class="text-sm text-on-surface-variant">Arsenal vs Chelsea</span>
<span class="px-2 py-0.5 rounded text-xs bg-white/10 text-white flex items-center gap-1 border border-white/10 backdrop-blur-sm">
<span class="w-2 h-2 rounded-full bg-white animate-pulse"></span>
                             Canlı
                         </span>
</div>
<div class="flex justify-between items-baseline">
<span class="text-lg font-medium text-white">Arsenal Kazanır</span>
<span class="text-white font-bold">%85</span>
</div>
</div>
<div class="mt-auto pt-4 border-t border-white/10 flex justify-between items-center">
<span class="text-sm text-on-surface-variant">Popülerlik: Yüksek</span>
<span class="text-sm text-white font-medium">Toplam Tahmin: 1.2M</span>
</div>
</div>
<!-- Stats Mini Cards -->
<div class="bg-white/5 backdrop-blur-[64px] border border-white/10 border-t-white/20 border-l-white/20 rounded-2xl p-6 flex flex-col items-center justify-center text-center gap-2 shadow-xl">
<span class="material-symbols-outlined text-3xl text-white">military_tech</span>
<span class="text-display-lg font-bold text-white">%68</span>
<span class="text-on-surface-variant text-sm">İsabet Oranı</span>
</div>
<div class="bg-white/5 backdrop-blur-[64px] border border-white/10 border-t-white/20 border-l-white/20 rounded-2xl p-6 flex flex-col items-center justify-center text-center gap-2 shadow-xl">
<span class="material-symbols-outlined text-3xl text-white">hotel_class</span>
<span class="text-display-lg font-bold text-white">1200</span>
<span class="text-on-surface-variant text-sm">Aylık Başarı Puanı</span>
</div>
<div class="bg-white/5 backdrop-blur-[64px] border border-white/10 border-t-white/20 border-l-white/20 rounded-2xl p-6 flex items-center justify-between group cursor-pointer hover:bg-white/10 transition-all shadow-xl">
<div class="flex flex-col gap-1">
<span class="text-lg font-medium text-white">Tüm Geçmişi Gör</span>
<span class="text-sm text-on-surface-variant">Geçmiş tahminleri incele</span>
</div>
<div class="w-10 h-10 rounded-full bg-white/10 border border-white/10 flex items-center justify-center group-hover:bg-white/20 text-white transition-colors backdrop-blur-sm">
<span class="material-symbols-outlined">arrow_forward</span>
</div>
</div>
</section>
</main>
<script>
        // Simple scroll effect for Top App Bar
        window.addEventListener('scroll', () => {
            const header = document.getElementById('top-app-bar');
            if (window.scrollY > 20) {
                header.classList.add('bg-[#0e0e0e]/80', 'backdrop-blur-md', 'shadow-sm');
                header.classList.remove('bg-transparent');
            } else {
                header.classList.remove('bg-[#0e0e0e]/80', 'backdrop-blur-md', 'shadow-sm');
                header.classList.add('bg-transparent');
            }
        });
    </script>


</body></html>
